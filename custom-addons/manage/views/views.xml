<odoo>
  <data>
    <!-- explicit list view definition -->
    <!--
    <record model="ir.ui.view" id="manage.list">
      <field name="name">manage list</field>
      <field name="model">manage.manage</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name"/>
          <field name="value"/>
          <field name="value2"/>
        </tree>
      </field>
    </record>
-->

    <!-- Developer module -->
    <record model="ir.ui.view" id="manage.developer_form">
      <field name="name">manage developer form</field>
      <field name="model">res.partner</field>
      <field name="inherit_id" ref="base.view_partner_form" />
      <field name="mode">primary</field>
      <field name="arch" type="xml">
        <!-- <xpath expr="//sheet/notebook/page[@name='internal_notes']" position="after">
          <page name="developer" string="Developer">
            <group>
              <field name="technologies" string="Tecnologías" widget="many2many_tags"/>
            </group>
          </page>
        </xpath> -->
        <page name="internal_notes" position="after">
          <page name="developer" string="Developer"
            attrs="{'invisible': [('is_developer', '=', False)]}">
            <group>
              <field name="is_developer" string="Developer" widget="boolean"
                attrs="{'invisible': True}" />
              <field name="technologies" string="Tecnologías" widget="many2many_tags" />
            </group>
          </page>
        </page>
      </field>
    </record>


    <!-- History module -->
    <record model="ir.ui.view" id="manage.history_list">
      <field name="name">manage history list</field>
      <field name="model">manage.history</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name" />
          <field name="description" />
          <field name="project" />
          <field name="tasks" />
          <field name="used_technologies" />
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="manage.history_form">
      <field name="name">manage history form</field>
      <field name="model">manage.history</field>
      <field name="arch" type="xml">
        <form>
          <group>
            <field name="project" />
            <field name="name" />
            <field name="description" />
            <field name="tasks" />
            <field name="used_technologies" />
          </group>
        </form>
      </field>
    </record>


    <!-- Sprint module -->
    <record model="ir.ui.view" id="manage.sprint_list">
      <field name="name">manage sprint list</field>
      <field name="model">manage.sprint</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name" />
          <field name="description" />
          <field name="project" />
          <field name="start_date" />
          <field name="duration" />
          <field name="end_date" />
          <field name="tasks" />
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="manage.sprint_form">
      <field name="name">manage sprint form</field>
      <field name="model">manage.sprint</field>
      <field name="arch" type="xml">
        <form>
          <group>
            <field name="project" />
            <field name="name" />
            <field name="description" />
            <field name="start_date" />
            <field name="duration" />
            <field name="end_date" />
            <field name="tasks" />
          </group>
        </form>
      </field>
    </record>


    <!-- Technology module -->
    <record model="ir.ui.view" id="manage.technology_list">
      <field name="name">manage technology list</field>
      <field name="model">manage.technology</field>
      <field name="arch" type="xml">
        <tree>
          <field name="name" />
          <field name="description" />
          <field name="photo" />
          <field name="tasks" />
        </tree>
      </field>
    </record>

    <record model="ir.ui.view" id="manage.technology_form">
      <field name="name">manage technology form</field>
      <field name="model">manage.technology</field>
      <field name="arch" type="xml">
        <form>
          <group>
            <field name="name" />
            <field name="description" />
            <field name="photo" />
            <field name="tasks" />
          </group>
        </form>
      </field>
    </record>


    <!-- actions opening views on models -->
    <!--
    <record model="ir.actions.act_window" id="manage.action_window">
      <field name="name">manage window</field>
      <field name="res_model">manage.manage</field>
      <field name="view_mode">tree,form</field>
    </record>
-->
    <!-- Developer module -->
    <record model="ir.actions.act_window" id="manage.action_developer_window">
      <field name="name">manage developer window</field>
      <field name="res_model">res.partner</field>
      <field name="domain">[('is_developer', '=', True)]</field>
      <field name="context">{'default_is_developer': True}</field>
      <field name="view_mode">tree,form</field>
    </record>

    <record model="ir.actions.act_window.view" id="manage.action_developer_window_tree">
      <field name="sequence" eval="1" />
      <field name="view_mode">tree</field>
      <field name="view_id" ref="base.view_partner_tree" />
      <field name="act_window_id" ref="manage.action_developer_window" />
    </record>

    <record model="ir.actions.act_window.view" id="manage.action_developer_window_form">
      <field name="sequence" eval="2" />
      <field name="view_mode">form</field>
      <field name="view_id" ref="manage.developer_form" />
      <field name="act_window_id" ref="manage.action_developer_window" />
    </record>


    <!-- History module -->
    <record model="ir.actions.act_window" id="manage.action_history_window">
      <field name="name">manage history window</field>
      <field name="res_model">manage.history</field>
      <field name="view_mode">tree,form</field>
    </record>

    <!-- Sprint module -->
    <record model="ir.actions.act_window" id="manage.action_sprint_window">
      <field name="name">manage sprint window</field>
      <field name="res_model">manage.sprint</field>
      <field name="view_mode">tree,form</field>
    </record>
    <!-- Technology module -->
    <record model="ir.actions.act_window" id="manage.action_technology_window">
      <field name="name">manage technology window</field>
      <field name="res_model">manage.technology</field>
      <field name="view_mode">tree,form</field>
    </record>

    <!-- server action to the one above -->
    <!--
    <record model="ir.actions.server" id="manage.action_server">
      <field name="name">manage server</field>
      <field name="model_id" ref="model_manage_manage"/>
      <field name="state">code</field>
      <field name="code">
        action = {
          "type": "ir.actions.act_window",
          "view_mode": "tree,form",
          "res_model": model._name,
        }
      </field>
    </record>
-->

    <!-- Top menu item -->
    <!--
    <menuitem name="manage" id="manage.menu_root"/>
-->

    <menuitem name="Manage" id="manage.menu_root" />


    <!-- menu categories -->
    <!--
    <menuitem name="Menu 1" id="manage.menu_1" parent="manage.menu_root"/>
    <menuitem name="Menu 2" id="manage.menu_2" parent="manage.menu_root"/>
-->
    <menuitem name="Management" id="manage.menu_1" parent="manage.menu_root" />

    <!-- actions -->
    <!--
    <menuitem name="List" id="manage.menu_1_list" parent="manage.menu_1"
              action="manage.action_window"/>
    <menuitem name="Server to list" id="manage" parent="manage.menu_2"
              action="manage.action_server"/>
-->

    <!-- Sprint module -->
    <menuitem name="Histories" id="manage.menu_1_history_list" parent="manage.menu_1"
      action="manage.action_history_window" />

    <!-- Sprint module -->
    <menuitem name="Sprints" id="manage.menu_1_sprint_list" parent="manage.menu_1"
      action="manage.action_sprint_window" />
    <!-- Developer module -->
    <menuitem name="Developers" id="manage.menu_1_developer_list" parent="manage.menu_1"
      action="manage.action_developer_window" />
    <!-- Technology module -->
    <menuitem name="Technologies" id="manage.menu_1_technology_list" parent="manage.menu_1"
      action="manage.action_technology_window" />
    <!-- <menuitem name="Server to list" id="manage" parent="manage.menu_2"
              action="manage.action_server"
    /> -->

  </data>
</odoo>